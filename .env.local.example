# ============================================
# SICOP Copilot — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# ============================================

# Supabase (públicas — seguras en cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase Service Role (SOLO server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Anthropic Claude API (SOLO server-side, nunca exponer en cliente)
ANTHROPIC_API_KEY=sk-ant-...

# Resend para emails transaccionales
RESEND_API_KEY=re_...

# Secret para proteger endpoints de cron
# Generar con: openssl rand -hex 32
CRON_SECRET=tu-secret-muy-largo-y-aleatorio

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Lemon Squeezy (pagos — Fase 5)
# Obtener en: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
# ID de tu tienda (Settings → General → Store ID)
LEMONSQUEEZY_STORE_ID=
# ID de variante del plan Pro (Products → tu producto → Variants → copy ID)
LEMONSQUEEZY_VARIANT_PRO=
# ID de variante del plan Business
LEMONSQUEEZY_VARIANT_BUSINESS=
# Secret para validar webhooks (Settings → Webhooks → secret)
LEMONSQUEEZY_WEBHOOK_SECRET=
# Poner "true" para usar modo test en desarrollo
LEMONSQUEEZY_TEST_MODE=true
