# ============================================
# SICOP Copilot — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# ============================================

# Supabase (públicas — seguras en cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase Service Role (SOLO server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Anthropic Claude API (SOLO server-side, nunca exponer en cliente)
ANTHROPIC_API_KEY=sk-ant-...

# Resend para emails transaccionales
RESEND_API_KEY=re_...

# Secret para proteger endpoints de cron
# Generar con: openssl rand -hex 32
CRON_SECRET=tu-secret-muy-largo-y-aleatorio

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (cuando se implemente monetización — Fase 5)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
